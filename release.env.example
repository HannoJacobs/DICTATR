DICTATR_CODESIGN_MODE="adhoc"
DICTATR_CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Set to:
# - accepted: signed and notarized builds that Gatekeeper should accept
# - rejected: signed but intentionally unnotarized builds that Gatekeeper should reject
# - skip: do not enforce spctl outcome
#
# Recommended defaults:
# - adhoc mode: rejected
# - developer_id mode without notarization: rejected
# - developer_id mode with notarization: accepted
DICTATR_SPCTL_EXPECT="rejected"
